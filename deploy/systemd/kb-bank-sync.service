[Unit]
Description=KB transaction synchronization to Google Sheets
Wants=network-online.target
After=network-online.target docker.service
Requires=docker.service

[Service]
Type=oneshot
User=ubuntu
Group=ubuntu
WorkingDirectory=/opt/kb-bank-sync
ExecStart=/opt/kb-bank-sync/scripts/run-sync.sh
TimeoutStartSec=15min
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
