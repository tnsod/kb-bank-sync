# KB 빠른조회 (실제 값은 .env에만 입력)
KB_QUICK_LOOKUP_URL=
KB_ACCOUNT_NUMBER=
KB_BIRTH_DATE=
KB_WEB_PASSWORD=

# 비워 두면 시트 최신 거래일과 실행 당일 KST를 기준으로 자동 계산
KB_LOOKUP_START_DATE=
KB_LOOKUP_END_DATE=

# Google Sheets 서비스 계정
# GOOGLE_SPREADSHEET_ID는 Spreadsheet 파일 URL에 포함된 파일 ID다.
# GOOGLE_SHEET_NAME은 파일명이 아니라 하단 워크시트 탭 이름이다.
GOOGLE_SPREADSHEET_ID=
GOOGLE_SHEET_NAME=거래내역

# Windows에서 직접 Node.js로 실행:
# GOOGLE_SERVICE_ACCOUNT_KEY_PATH=C:\secure\google-service-account.json
#
# Windows Docker Compose (C:/... 형식 권장):
# GOOGLE_SERVICE_ACCOUNT_KEY_PATH=C:/secure/google-service-account.json
#
# macOS (POSIX 절대경로):
# GOOGLE_SERVICE_ACCOUNT_KEY_PATH=/Users/USERNAME/secure/google-service-account.json
#
# Linux (POSIX 절대경로):
# GOOGLE_SERVICE_ACCOUNT_KEY_PATH=/opt/kb-bank-sync/secrets/google-service-account.json
#
# Cloud Run 또는 Docker 컨테이너 내부 Secret 마운트 경로:
# GOOGLE_SERVICE_ACCOUNT_KEY_PATH=/run/secrets/google-service-account.json
# Compose는 호스트 경로의 파일을 위 컨테이너 경로에 read-only로 마운트한다.
# Docker 내부에서는 호스트 경로를 직접 사용하지 않는다.
# Cloud Run은 Secret Manager 파일 마운트 경로를 사용한다.
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=

# 시트에서 가장 최근 거래일을 기준으로 이 일수만큼 이전부터 다시 조회한다.
# 오늘을 기준으로 단순히 N일을 조회하는 설정이 아니다.
SYNC_OVERLAP_DAYS=3
INITIAL_LOOKBACK_MONTHS=6

# 안전한 조회 테스트
DRY_RUN=true
ENABLE_SHEETS_WRITE=false

# 실제 운영 시:
# DRY_RUN=false
# ENABLE_SHEETS_WRITE=true
# PowerShell에서 설정한 프로세스 환경변수는 .env보다 우선한다.

# 운영 기본 비활성화
ENABLE_DEEP_DIAGNOSTICS=false
ENABLE_RESPONSE_MEMORY_INSPECTION=false
ENABLE_SUBMIT_TRACING=false

PLAYWRIGHT_BROWSER_MODE=new-headless
PLAYWRIGHT_SUBMIT_CLICK_MODE=locator
LOG_LEVEL=info
TZ=Asia/Seoul
NODE_ENV=production
